# OpenAI
OPENAI_API_KEY=sk-...

# OpenBox Core
OPENBOX_URL=https://your-openbox-instance.com
OPENBOX_API_KEY=obx_live_...

# Optional
PORT=3142           # HTTP server port (default: 3142)
SERVER_MODE=false   # Set to "true" or pass --server to run as HTTP server
OPENBOX_DEBUG=1     # Uncomment to log governance requests/responses
